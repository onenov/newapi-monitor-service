# =========================
# 服务基础配置
# =========================

# 监控服务监听端口。
# 例如：43100、4024
PORT=4024

# 监控页面与 API 的基础路径。
# 留空表示直接部署在根路径：
#   页面入口：/
#   API 路径：/api/*
#
# 如果你要挂在子路径，例如通过 Nginx 挂到 /monitor，
# 则填写：
#   MONITOR_BASE_PATH=/monitor
# 此时：
#   页面入口：/monitor
#   静态资源：/monitor/static/*
#   API 路径：/monitor/api/*
MONITOR_BASE_PATH=

# API 路径前缀。
# 一般保持默认即可，不建议随意修改。
API_PREFIX=/api

# 允许的跨域来源。
# 开发阶段可以填 *，生产环境建议改成你的实际域名。
# 例如：
#   CORS_ORIGIN=https://your-domain.com
CORS_ORIGIN=*

# =========================
# 访问鉴权
# =========================

# 可选。设置后，访问监控服务的 API 需要携带令牌。
# 支持以下传法：
# 1. Authorization: Bearer <token>
# 2. x-api-key: <token>
# 3. 在仪表盘 URL 上追加 ?monitor_api_token=<token>
#
# 如果你不需要 API 鉴权，可以留空。
MONITOR_API_TOKEN=

# =========================
# 搜索验证（极验）
# =========================

# 可选，但建议开启。
# 配置后，按 Key / 渠道 ID 搜索时，需要：
# 1. 通过极验验证，或
# 2. 请求里带有效的 MONITOR_API_TOKEN
#
# 如果不配置这两个变量，搜索接口将不会自动启用极验校验能力。
GEETEST_CAPTCHA_ID=
GEETEST_CAPTCHA_KEY=

# =========================
# PostgreSQL 数据库配置
# =========================

# new-api 使用的 PostgreSQL 主机地址。
# 如果监控服务部署在宿主机，而数据库端口映射到了本机，例如 15432：
#   NEWAPI_DB_HOST=127.0.0.1
# 如果监控服务和 PostgreSQL 在同一个 Docker Compose 网络：
#   NEWAPI_DB_HOST=postgres
NEWAPI_DB_HOST=your_database_host

# PostgreSQL 端口。
# 宿主机场景通常填映射后的端口，例如 15432。
# 同 Compose 网络下通常填容器内端口 5432。
NEWAPI_DB_PORT=15432

# PostgreSQL 用户名。
# 对应 new-api 数据库的实际用户名。
NEWAPI_DB_USER=your_database_user

# PostgreSQL 密码。
# 对应上面用户名的实际密码。
NEWAPI_DB_PASSWORD=your_database_password

# PostgreSQL 数据库名。
# 默认常见为 new-api。
NEWAPI_DB_NAME=new-api

# 是否启用 SSL 连接数据库。
# 可选值：
#   true
#   false
# 大多数本地部署、内网部署、Docker Compose 部署都可先填 false。
NEWAPI_DB_SSL=false

# =========================
# 上游 new-api 站点配置读取地址
# =========================

# new-api 的访问地址，用于读取站点名称、Logo、配额单位等前端展示信息。
# 例如：
#   NEWAPI_URL=http://127.0.0.1:3000
#   NEWAPI_URL=https://example.com
NEWAPI_URL=http://127.0.0.1:3000

# =========================
# 缓存配置
# =========================

# 内存缓存时间，单位秒。
# 默认 900 秒，即 15 分钟。
# 数值越大，请求数据库的频率越低，但数据更新会更不实时。
CACHE_TTL_SECONDS=900
